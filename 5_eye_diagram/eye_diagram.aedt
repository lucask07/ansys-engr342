			MS_TRL_FS(1002, 0, 0, 2, 'Ansoft built-in component', 1502913463, '', 'Nexxim Circuit Elements\\Distributed\\Distributed:trl_fs', '', 'Distributed Footprints:TRL', 'MS Transmission Line, Field Solver', 'NXMSTRLFS.htm', 'nexximcomponents.chm', 'mstrl.bmp', 'Nexxim Circuit Elements\\Distributed\\Microstrip\\Transmission Lines', 'SysLibrary', 'psessions', '', 1113336357, '', 0, 99004)
			EYEPROBE(1002, 0, 0, 1, 'Ansoft built-in component', 1712783160, '', 'Nexxim Circuit Elements\\Nexxim_symbols:nexx_eyeprb', '', '', 'Eye Probe', 'NXEYEPROBE.htm', 'nexximcomponents.chm', 'iprb.bmp', 'Nexxim Circuit Elements\\Probes', 'SysLibrary', '', '', 1177016630, '', 0, 99016)
			TRL_T(1002, 0, 0, 4, 'Ansoft built-in component', 1515431694, '', 'Nexxim Circuit Elements\\Nexxim_symbols:nexx_t', '', '', 'T-Element Lossless Transmission Line', 'NXTELEM.htm', 'nexximcomponents.chm', 'trltd_ref.bmp', 'Nexxim Circuit Elements\\Transmission Lines', 'SysLibrary', '', '', 1308840237, '', 0, 99004)
			MS_TRL(1002, 0, 0, 2, 'Ansoft built-in component', 1502913463, '', 'Nexxim Circuit Elements\\Distributed\\Distributed:trl', '', 'Distributed Footprints:TRL', 'MS Transmission Line, Physical Length', 'NXMSTRL.htm', 'nexximcomponents.chm', 'mstrl.bmp', 'Nexxim Circuit Elements\\Distributed\\Microstrip\\Transmission Lines', 'SysLibrary', '', '', 1127917543, '', 0, 4)
			EYESOURCE(1002, 0, 0, 1, 'Ansoft built-in component', 1712783160, '', 'Nexxim Circuit Elements\\Nexxim_symbols:nexx_eyesrc', '', '', 'Eye Source', 'NXEYESOURCE.htm', 'nexximcomponents.chm', 'iprb.bmp', 'Nexxim Circuit Elements\\Independent Sources', 'SysLibrary', '', '', 1177016630, '', 0, 99024)
		$end 'DefInfo'
		$begin 'Compdefs'
			$begin 'Circuit1'
				Library=''
				CircuitEnv=0
				Refbase='U'
				NumParts=1
				ModSinceLib=true
				$begin 'Properties'
					TextProp('Representation', 'SRD', '', 'Circuit1')
					TextProp('Owner', 'SRD', '', 'Circuit Design')
				$end 'Properties'
				CompExtID=6
			$end 'Circuit1'
			$begin 'TRLE_NX'
				Library='Nexxim Circuit Elements\\Ideal Distributed'
				CircuitEnv=0
				Refbase='A'
				NumParts=1
				ModSinceLib=false
				Terminal('n1', 'n1', 'A', false, 0, 1, '', 'Electrical', '')
				Terminal('n2', 'n2', 'A', false, 0, 1, '', 'Electrical', '')
				CompExtID=1
				$begin 'Parameters'
					VariablePropNU('Z', 'D', 'Characteristic impedance', '50', 'ohm', AdditionalPropInfo='')
					VariablePropNU('E', 'D', 'Electrical length', '45deg', 'deg', AdditionalPropInfo='')
					VariableProp('A', 'D', 'Attenuation at F', '0')
					VariablePropNU('F', 'D', 'Reference frequency for E & A', '1GHz', 'Hz', AdditionalPropInfo='')
					TextProp('ModelName', 'SHD', '', 'TRLE')
					ButtonProp('CosimDefinition', 'SD', '', 'Edit', 'Edit', 40501, ButtonPropClientData())
					MenuProp('CoSimulator', 'D', '', 'DefaultNetlist', 0)
				$end 'Parameters'
				$begin 'CosimDefinitions'
					$begin 'CosimDefinition'
						CosimulatorType=4
						CosimDefName='DefaultNetlist'
						IsDefinition=true
						Connect=false
						Data(Circuit='TRLE:@ID %0 %1 ?Z(Z=@Z) ?E(E=@E) ?F(F=@F) *A(A=@A)', 'Nexxim Circuit'='A@ID %0 %1 ?Z(Z=@Z) ?E(E=@E) ?F(F=@F) *A(A=@A) COMPONENT=trle', System='TRLE:@ID %0 %1 ?Z(Z=@Z) ?E(E=@E) ?F(F=@F) *A(A=@A)')
						GRef(Circuit='', 'Nexxim Circuit'='', System='')
					$end 'CosimDefinition'
					DefaultCosim='DefaultNetlist'
				$end 'CosimDefinitions'
			$end 'TRLE_NX'
			$begin 'RES_'
				Library='Nexxim Circuit Elements\\Resistors'
				CircuitEnv=0
				Refbase='R'
				NumParts=1
				ModSinceLib=false
				Terminal('terminals_0', 'terminals_0', 'A', false, 6, 1, '', 'Electrical', '0')
				Terminal('terminals_1', 'terminals_1', 'A', false, 7, 1, '', 'Electrical', '0')
				CompExtID=1
				$begin 'Parameters'
					TextProp('LabelID', 'HD', 'Property string for netlist ID', 'R@ID')
					VariableProp('R', 'D', 'Resistance (Ohm)', '50')
					MenuProp('ADD_NOISE', 'HD', '1=generate noise data, 0=no noise data', '0,1', 1)
					VariablePropNU('DTEMP', 'HD', 'Diff betw device temp and circuit temp', '0cel', 'cel', AdditionalPropInfo='')
					TextProp('ModelName', 'SHD', '', 'RES_')
					ButtonProp('CosimDefinition', 'D', '', 'Edit', 'Edit', 40501, ButtonPropClientData())
					MenuProp('CoSimulator', 'D', '', 'DefaultNetlist', 0)
				$end 'Parameters'
				$begin 'CosimDefinitions'
					$begin 'CosimDefinition'
						CosimulatorType=4
						CosimDefName='DefaultNetlist'
						IsDefinition=true
						Connect=true
						Data('Nexxim Circuit'='R@ID %0 %1 ?R(@R) *ADD_NOISE(NOISE=@ADD_NOISE) *DTEMP(DTEMP=@DTEMP)')
						GRef('Nexxim Circuit'='')
					$end 'CosimDefinition'
					DefaultCosim='DefaultNetlist'
				$end 'CosimDefinitions'
			$end 'RES_'
			$begin 'MS_TRL_FS'
				Library='Nexxim Circuit Elements\\Distributed\\Microstrip\\Transmission Lines'
				CircuitEnv=0
				Refbase='W'
				NumParts=1
				ModSinceLib=false
				Terminal('n1', 'n1', 'A', true, 0, 1, '', 'Electrical', '')
				Terminal('n2', 'n2', 'A', true, 1, 1, '', 'Electrical', '')
				CompExtID=1
				$begin 'Parameters'
					VariablePropNU('W', 'D', 'Width of conductors', '1mm', 'meter', AdditionalPropInfo='')
					VariablePropNU('L', 'D', 'Length of conductors', '10mm', 'meter', AdditionalPropInfo='')
					VariablePropNU('H', 'D', 'Thickness of dielectric layer', '1mm', 'meter', AdditionalPropInfo='')
					VariablePropNU('HU', 'D', 'Thickness of air layer', '1mm', 'meter', AdditionalPropInfo='')
					VariablePropNU('T1', 'D', 'Thickness of conductors', '1mm', 'meter', AdditionalPropInfo='')
					VariablePropNU('T2', 'D', 'Thickness of ground layer', '1mm', 'meter', AdditionalPropInfo='')
					VariablePropNU('CONDUCTIVITY', 'D', 'Conductivity of conductors', '57600000', '', AdditionalPropInfo='')
					VariablePropNU('ER', 'D', 'Dielectric constant', '4.5', '', AdditionalPropInfo='')
					VariablePropNU('TAND', 'D', 'Dielectric loss tangent', '0', '', AdditionalPropInfo='')
					TextProp('ModelName', 'SHD', '', 'MS_CPL')
					ButtonProp('CosimDefinition', 'SD', '', 'Edit', 'Edit', 40501, ButtonPropClientData())
					VariablePropNU('P', 'HD', '', 'L', 'meter', AdditionalPropInfo='')
					MenuProp('CoSimulator', 'D', '', 'DefaultNetlist,Planar EM', 0)
				$end 'Parameters'
				$begin 'CosimDefinitions'
					$begin 'CosimDefinition'
						CosimulatorType=0
						CosimDefName='Planar EM'
						IsDefinition=true
						Connect=true
						CosimStackup='Layout stackup'
						CosimDmbedRatio=3
						UsePlanarEM=false
					$end 'CosimDefinition'
					$begin 'CosimDefinition'
						CosimulatorType=4
						CosimDefName='DefaultNetlist'
						IsDefinition=true
						Connect=false
						Data('Nexxim Circuit'='W@ID %0 0 %1 0  N=1  L=@L FSMODEL=MSTRLFS_@(ID) \
.MATERIAL cond1_@(ID) METAL CONDUCTIVITY=@CONDUCTIVITY \
.MATERIAL diel1_@(ID) DIELECTRIC ER=@ER LOSSTANGENT=@TAND  \
.SHAPE rect1_@(ID) RECTANGLE WIDTH=@W HEIGHT=@T1 \
.LAYERSTACK microstrip_@(ID)   \
+ LAYER=(cond1_@(ID),@T2)  \
+ LAYER=(diel1_@(ID),@H)  \
+ LAYER=(AIR, @HU)  \
.MODEL MSTRLFS_@(ID) W MODELTYPE=Fieldsolver  \
+ LAYERSTACK=microstrip_@(ID)  \
+ CONDUCTOR=(SHAPE=rect1_@(ID), ORIGIN=(0, \\\' @T2 + @H \\\' ), MATERIAL=cond1_@(ID), TYPE=SIGNAL)  ')
						GRef('Nexxim Circuit'='')
					$end 'CosimDefinition'
					DefaultCosim='DefaultNetlist'
				$end 'CosimDefinitions'
			$end 'MS_TRL_FS'
			$begin 'EYEPROBE'
				Library='Nexxim Circuit Elements\\Probes'
				CircuitEnv=0
				Refbase='A'
				NumParts=1
				ModSinceLib=false
				Terminal('n1', 'n1', 'A', false, 0, 1, '', 'Electrical', '')
				$begin 'Properties'
