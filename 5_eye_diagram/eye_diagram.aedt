					MenuProp('CoSimulator', 'OHD', '', 'DefaultNetlist', 0)
					ButtonProp('CosimDefinition', 'SOHD', '', 'Edit', 'Edit', 40501, ButtonPropClientData())
					ButtonProp('FFE_data', 'SOD', 'FFE data', '', '', 55902, ButtonPropClientData('', ''))
					ButtonProp('BitPattern', 'SOD', 'Bit pattern for QuickEye', 'random_bit_count=2.5e5 random_seed=1', '', 55904, ButtonPropClientData('random_bit_count=2.5e5 random_seed=1', ''))
					ButtonProp('txrj', 'SOD', 'Gaussian (random) jitter std deviation', '', '', 55910, ButtonPropClientData('', ''))
					ButtonProp('txuj', 'SOD', 'Uniform (random) jitter amplitude', '', '', 55910, ButtonPropClientData('', ''))
					ButtonProp('txpj', 'SOD', 'Periodic (random) jitter amplitude', '', '', 55910, ButtonPropClientData('', ''))
					ButtonProp('SpreadSpectrum', 'SOD', 'Spread Spectrum Data', '', '', 55912, ButtonPropClientData('', 'ss_enable=0 ss_profile=triangular ss_spread=down ss_freq_val=33 ss_freq_unit=kHz ss_d=0.5'))
					ValuePropNU('UIorBPSValue', 'OD', 'Enter a value for the Unit Interval (time interval of one symbol) or Bits Per Second (bit rate)', '2e-10s', 0, 's', AdditionalPropInfo='')
					ValueProp('trise', 'OD', 'Rise time of the source', '50ps', 0)
					ValueProp('tfall', 'OD', 'Fall time of the source', '50ps', 0)
