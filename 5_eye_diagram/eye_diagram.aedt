				$end 'Properties'
				CompExtID=1
				$begin 'Parameters'
					TextProp('Name', 'D', 'Name of probe', 'required')
					MenuProp('source_name', 'D', 'Associated source name', '', 0)
					ButtonProp('EyeMeasurementFunctions', 'SD', '', '', '', 55923, ButtonPropClientData('', ''))
					ButtonProp('DFE_data', 'SD', 'DFE data', '', '', 55923, ButtonPropClientData('', ''))
					ButtonProp('CTLE_data', 'SD', 'CTLE data', '', '', 55923, ButtonPropClientData('', ''))
					TextProp('ModelName', 'SHD', '', 'EYEPROBE')
					ButtonProp('CosimDefinition', 'SD', '', 'Edit', 'Edit', 40501, ButtonPropClientData())
					TextProp('COMPONENT', 'RHD', '', 'EYE_PROBE')
					MenuProp('CoSimulator', 'D', '', 'DefaultNetlist', 0)
				$end 'Parameters'
				$begin 'CosimDefinitions'
					$begin 'CosimDefinition'
						CosimulatorType=4
						CosimDefName='DefaultNetlist'
						IsDefinition=true
						Connect=false
						Data('Nexxim Circuit'='AEYEPROBE@ID %0 COMPONENT=@COMPONENT SOURCE_NAME=@SOURCE_NAME *DFE_DATA(@DFE_DATA) *CTLE_DATA(@CTLE_DATA) ')
						GRef('Nexxim Circuit'='')
					$end 'CosimDefinition'
					DefaultCosim='DefaultNetlist'
				$end 'CosimDefinitions'
			$end 'EYEPROBE'
			$begin 'TRL_T'
				Library='Nexxim Circuit Elements\\Transmission Lines'
				CircuitEnv=0
				Refbase='T'
				NumParts=1
				ModSinceLib=false
				Terminal('n1', 'n1', 'A', false, 0, 1, '', 'Electrical', '0')
				Terminal('n2', 'n2', 'A', false, 1, 1, '', 'Electrical', '0')
				Terminal('n3', 'n3', 'A', false, 2, 1, '', 'Electrical', '0')
				Terminal('n4', 'n4', 'A', false, 3, 1, '', 'Electrical', '0')
				CompExtID=1
				$begin 'Parameters'
					TextProp('LabelID', 'HD', 'Property string for netlist ID', 'T@ID')
					VariablePropNU('Z0', 'D', 'Characteristic impedance', '50ohm', 'ohm', AdditionalPropInfo='')
					VariablePropNU('TD', 'D', 'Time delay (nan=None). If not specified, TD is calculated as NL/F.', 'nan s', 's', AdditionalPropInfo='')
					VariablePropNU('F', 'D', 'Frequency (nan=None). Ignored when TD is specified, required when TD not specified.', 'nan Hz', 'Hz', AdditionalPropInfo='')
					VariableProp('NL', 'D', 'Normalized length with respect to wavelength. Ignored when TD is specified, required when TD not specified.', '0.25')
					ButtonProp('CosimDefinition', 'D', '', 'Edit', 'Edit', 40501, ButtonPropClientData())
					MenuProp('CoSimulator', 'D', '', 'DefaultNetlist', 0)
				$end 'Parameters'
				$begin 'CosimDefinitions'
					$begin 'CosimDefinition'
						CosimulatorType=4
						CosimDefName='DefaultNetlist'
						IsDefinition=true
						Connect=true
						Data('Nexxim Circuit'='T@ID %0 %1 %2 %3 ?Z0(Z0=@Z0) *TD(TD=@TD) *F(F=@F) *NL(NL=@NL)')
						GRef()
					$end 'CosimDefinition'
					DefaultCosim='DefaultNetlist'
				$end 'CosimDefinitions'
			$end 'TRL_T'
			$begin 'MS_TRL'
				Library='Nexxim Circuit Elements\\Distributed\\Microstrip\\Transmission Lines'
				CircuitEnv=0
				Refbase='A'
				NumParts=1
				ModSinceLib=false
				Terminal('n1', 'n1', 'A', false, 0, 1, '', 'Electrical', '0')
				Terminal('n2', 'n2', 'A', false, 1, 1, '', 'Electrical', '0')
				CompExtID=1
				$begin 'Parameters'
					VariablePropNU('W', 'D', 'Conductor width', '1mm', 'meter', AdditionalPropInfo='')
					VariablePropNU('P', 'D', 'Physical length', '10mm', 'meter', AdditionalPropInfo='')
					TextProp('COMPONENT', 'RHD', 'Component name', 'TRL')
					ButtonProp('SUB', 'SD', 'Substrate name', '', '', 0, ButtonPropClientData())
					ButtonProp('TRL', 'SD', 'TRL properties', 'TRL', '', 0, ButtonPropClientData())
					ButtonProp('SystemNetList', 'HD', '', 'MSTRL:@ID %0 %1 ?W(W=@W) ?P(P=@P) ?SUB(SUB=@SUB)', 'MSTRL:@ID %0 %1 ?W(W=@W) ?P(P=@P) ?SUB(SUB=@SUB)', 1, ButtonPropClientData())
					TextProp('ModelName', 'SHD', '', 'MS_TRL')
					ButtonProp('CosimDefinition', 'D', '', 'Edit', 'Edit', 40501, ButtonPropClientData())
					MenuProp('CoSimulator', 'D', '', 'DefaultNetlist,Planar EM', 0)
				$end 'Parameters'
				$begin 'CosimDefinitions'
					$begin 'CosimDefinition'
						CosimulatorType=0
						CosimDefName='Planar EM'
						IsDefinition=true
						Connect=true
						CosimStackup='Layout stackup'
						CosimDmbedRatio=3
						UsePlanarEM=false
					$end 'CosimDefinition'
					$begin 'CosimDefinition'
						CosimulatorType=4
						CosimDefName='DefaultNetlist'
						IsDefinition=true
						Connect=true
						Data('Nexxim Circuit'='A@ID %0 %1 ?W(W=@W) ?P(P=@P) COMPONENT=@COMPONENT ?SUB(SUBSTRATE=@SUB)')
						GRef()
					$end 'CosimDefinition'
					DefaultCosim='DefaultNetlist'
				$end 'CosimDefinitions'
			$end 'MS_TRL'
			$begin 'EYESOURCE'
				Library='Nexxim Circuit Elements\\Independent Sources'
				CircuitEnv=0
				Refbase='A'
				NumParts=1
				ModSinceLib=false
				Terminal('n1', 'n1', 'A', false, 0, 1, '', 'Electrical', '')
				$begin 'Properties'
					TextProp('OutputQuantity', 'RHD', '', 'Current')
				$end 'Properties'
				CompExtID=1
				$begin 'Parameters'
					VariableProp('resistance', 'D', 'Resistance (Ohm)', '50ohm')
					VariableProp('vlow', 'D', 'Low voltage of the source', '0V')
					VariableProp('vhigh', 'D', 'High voltage of the source', '1V')
					VariableProp('trise', 'D', 'Rise time of the source', '500ps')
					VariableProp('tfall', 'D', 'Fall time of the source', '500ps')
					VariableProp('phase_delay', 'D', 'Phase of the source in seconds', '0s')
					MenuProp('modulation', 'D', 'Serial data modulation. NRZ (2 voltage levels, 1 bit per symbol) or PAM-4 (4 levels, 2 bits per symbol)', 'NRZ,PAM4', 0)
					MenuProp('coding_PAM4_only', 'D', 'Relevant for PAM-4 only. Coding for mapping low-to-high voltage levels to PAM-4 symbols. Gray= 00,01,11,10. Linear = 00,01,10,11.', 'Gray,Linear', 0)
					MenuProp('UIorBPS', 'D', 'Choose UnitInterval or BitsPerSecond. UnitInterval is the time interval of one symbol, BitsPerSecond is the bit rate.', 'UnitInterval,BitsPerSecond', 0)
					VariablePropNU('UIorBPSValue', 'D', 'Enter a value for the Unit Interval (time interval of one symbol) or Bits Per Second (bit rate)', '1e-09s', 's', AdditionalPropInfo='')
					MenuProp('DCDFractionorTime', 'D', 'Fraction = decimal fraction of UI, 0 <= DCD <= 1. Time = absolute time in seconds', 'Fraction, Time', 0)
					VariableProp('dcd', 'D', 'Duty cycle distortion', '0')
					ButtonProp('txrj', 'SD', 'Gaussian (random) jitter std deviation', '', '', 55923, ButtonPropClientData('', ''))
					ButtonProp('txpj', 'SD', 'Periodic (random) jitter amplitude', '', '', 55923, ButtonPropClientData('', ''))
					ButtonProp('txuj', 'SD', 'Uniform (random) jitter amplitude', '', '', 55923, ButtonPropClientData('', ''))
					ButtonProp('txcj', 'D', 'Name of user-defined transmit jitter file', '', '<Project>', 3, ButtonPropClientData(InternalFormatText='<Project>'))
					VariableProp('repeat_count', 'D', 'Number of times to repeat the bit pattern.', '0')
					VariableProp('step_resp_num_ui', 'D', 'Num of UIs for initial step response', '100')
					MenuProp('do_encoding', 'D', 'NRZ only, ignored with PAM4', 'None,8b10b,64b66b,128b130b,128b132b', 0)
					CheckboxProp('hold_last_bit', 'D', 'Hold last bit or repeat the sequence.', false)
					ButtonProp('FFE_data', 'SD', 'FFE data', '', '', 55923, ButtonPropClientData('', ''))
					ButtonProp('BitPattern', 'SD', 'Bit pattern for QuickEye', 'random_bit_count=2.5e5 random_seed=1', '', 55923, ButtonPropClientData('random_bit_count=2.5e5 random_seed=1', ''))
					TextProp('ModelName', 'SHD', '', 'EYESOURCE')
					ButtonProp('SpreadSpectrum', 'SD', 'Spread Spectrum Data', '', '', 55923, ButtonPropClientData('', 'ss_enable=0 ss_profile=triangular ss_spread=down ss_freq_val=33 ss_freq_unit=kHz ss_d=0.5'))
					TextProp('COMPONENT', 'RHD', '', 'EYE_SOURCE')
					ButtonProp('CosimDefinition', 'SD', '', 'Edit', 'Edit', 40501, ButtonPropClientData())
					MenuProp('CoSimulator', 'D', '', 'DefaultNetlist', 0)
				$end 'Parameters'
				$begin 'MultiTabParameters'
					Bits('-Voltage profile', 'vlow', 'vhigh', 'trise', 'tfall', 'phase_delay', 'UIorBPS', 'UIorBPSValue', '-Bit Pattern', 'repeat_count', 'hold_last_bit', 'BitPattern', 'step_resp_num_ui', '-Internal Impedance', 'resistance')
					Jitter_Clock('-Jitter', 'DCDFractionorTime', 'dcd', 'txrj', 'txpj', 'txuj', 'txcj', '-Spread Spectrum Clocking', 'SpreadSpectrum')
					Equalization('FFE_data')
					Coding('do_encoding', '-LineCoding', 'modulation', 'coding_PAM4_only')
				$end 'MultiTabParameters'
				$begin 'CosimDefinitions'
					$begin 'CosimDefinition'
						CosimulatorType=4
						CosimDefName='DefaultNetlist'
						IsDefinition=true
						Connect=false
						Data('Nexxim Circuit'='AEYESOURCE@ID %0 COMPONENT=@COMPONENT RESISTANCE=@RESISTANCE *TRISE(TRISE=@TRISE) *TFALL(TFALL=@TFALL) *VLOW(VLOW=@VLOW) *VHIGH(VHIGH=@VHIGH) *PHASE_DELAY(PHASE_DELAY=@PHASE_DELAY) modulation=@modulation coding=@coding_PAM4_only ?(UIorBPS==UnitInterval)(*UIorBPSValue(UI=@UIorBPSValue)):(BPS=@UIorBPSValue) *TXRJ(TXRJ=@TXRJ) *TXPJ(TXPJ=@TXPJ) *TXUJ(TXUJ=@TXUJ) *TXCJ(TXCJ=@TXCJ) *DCD(?DCDFractionorTime(?DCDFractionorTime==Fraction(DCD=@DCD):(DCD_TIME=@DCD)):(DCD=@DCD))  *REPEAT_COUNT(REPEAT_COUNT=@REPEAT_COUNT) *STEP_RESP_NUM_UI(STEP_RESP_NUM_UI=@STEP_RESP_NUM_UI) ?(DO_ENCODING==None)(DO_ENCODING=0):(?(DO_ENCODING==8b10b)(DO_ENCODING=1):(?(DO_ENCODING==64b66b)(DO_ENCODING=2):(?(DO_ENCODING==128b130b)(DO_ENCODING=3):(?(DO_ENCODING==128b132b)(DO_ENCODING=4))))) ?(HOLD_LAST_BIT==true)(HOLD_LAST_BIT=1) *FFE_DATA(@FFE_DATA) *BITPATTERN(@BITPATTERN) *SPREADSPECTRUM(@SPREADSPECTRUM)')
						GRef('Nexxim Circuit'='')
					$end 'CosimDefinition'
					DefaultCosim='DefaultNetlist'
				$end 'CosimDefinitions'
			$end 'EYESOURCE'
		$end 'Compdefs'
	$end 'Definitions'
	DesignIDServer=2
	MoveBackwards=false
	$begin 'NexximCircuit'
		RepRewriteV2=true
		Name='Circuit1'
		DesignID=0
